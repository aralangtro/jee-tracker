# Choose your provider's base URL and models
# Uncomment the block for the provider you want to use.

# ====================================================================================
# ⚠️ WARNING: For the best user experience and faster reply times, 
# it is highly recommended to use lighter/faster models (e.g. gpt-4o-mini, 
# gemini-2.5-flash, claude-3-haiku, llama-3.1-8b).
# ====================================================================================

# --- NVIDIA NIM (Default) ---
# API_BASE_URL=integrate.api.nvidia.com
# API_PATH=/v1/chat/completions
# TEXT_MODEL=meta/llama-3.3-70b-instruct
# VISION_MODEL=meta/llama-3.2-90b-vision-instruct
# NVIDIA_REASON_KEY=put_your_nvidia_api_key_here
# NVIDIA_VISION_KEY=put_your_nvidia_api_key_here

# --- OpenAI ---
# API_BASE_URL=api.openai.com
# API_PATH=/v1/chat/completions
# TEXT_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o-mini
# NVIDIA_REASON_KEY=put_your_openai_api_key_here
# NVIDIA_VISION_KEY=put_your_openai_api_key_here

# --- Google Gemini ---
# API_BASE_URL=generativelanguage.googleapis.com
# API_PATH=/v1beta/openai/chat/completions
# TEXT_MODEL=gemini-2.5-flash
# VISION_MODEL=gemini-2.5-flash
# NVIDIA_REASON_KEY=put_your_gemini_api_key_here
# NVIDIA_VISION_KEY=put_your_gemini_api_key_here

# --- Anthropic ---
# API_BASE_URL=api.anthropic.com
# API_PATH=/v1/messages
# TEXT_MODEL=claude-3-haiku-20240307
# VISION_MODEL=claude-3-haiku-20240307
# NVIDIA_REASON_KEY=put_your_anthropic_api_key_here
# NVIDIA_VISION_KEY=put_your_anthropic_api_key_here
